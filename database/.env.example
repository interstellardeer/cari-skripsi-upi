# Copy this file to .env and fill in your values
# cp .env.example .env

# === OpenRouter (Embedding) ===
# Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# === Qdrant Cloud ===
# Get from: https://cloud.qdrant.io → your cluster → API Keys
QDRANT_URL=https://<your-cluster-id>.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=
