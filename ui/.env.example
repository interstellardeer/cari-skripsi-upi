# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# === OpenRouter (Embedding + LLM) ===
# Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# === Qdrant Cloud ===
# Get from: https://cloud.qdrant.io → your cluster → API Keys
QDRANT_URL=https://<your-cluster-id>.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=

# === NextAuth.js ===
# For local dev use http://localhost:3000, for prod use your Vercel URL
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
# Or PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
NEXTAUTH_SECRET=

# === Google OAuth ===
# Get from: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs must include: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Vercel KV (Rate Limiting) ===
# Get from: https://vercel.com/dashboard → Storage → KV → your database → .env.local tab
KV_REST_API_URL=
KV_REST_API_TOKEN=
